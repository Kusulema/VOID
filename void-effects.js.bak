/* ======================================================================
   THE VOID — TERMINAL MALFUNCTION SYSTEM
   ====================================================================== */

const clickSound = document.getElementById('terminalClick');

const playClick = () => {
    if (!clickSound) {
        return;
    }

    try {
        clickSound.currentTime = 0;
        const promise = clickSound.play();
        if (promise && typeof promise.catch === 'function') {
            promise.catch(() => {});
        }
    } catch (error) {
        // ignore autoplay errors
    }
};

const getCart = () => {
    try {
        return JSON.parse(localStorage.getItem('voidCart') || '[]');
    } catch (error) {
        return [];
    }
};

const setCart = (cart) => {
    localStorage.setItem('voidCart', JSON.stringify(cart));
};

const updateCartBadge = () => {
    /* ======================================================================
VOID — UI behaviour helpers (documented)

This file contains client-side UI utilities for The VOID project:
- Sound feedback for interactive controls
- Lightweight client-side cart stored in localStorage
- Cart rendering and badge updates
- Review carousel with optional submission handling
- Generic popup/modal helpers and a simple auth gating modal
- Wishlist toggle behaviour (requires server endpoint)

Documentation style: JSDoc headers for exported/internal functions
and inline comments for non-obvious logic blocks.
======================================================================
    */

    /**
     * Element reference to the short click sound used for UI interactions.
     * May be null if the element is not present in the DOM.
     * @type {HTMLAudioElement|null}
     */
    const clickSound = document.getElementById('terminalClick');


    /**
     * Play the UI click sound safely.
     * Uses the returned Promise from HTMLMediaElement.play() if available
     * and quietly ignores browsers' autoplay/security rejections.
     */
    const playClick = () => {
        if (!clickSound) return;

        try {
            // Rewind to start so quick repeated clicks play audibly
            clickSound.currentTime = 0;
            const promise = clickSound.play();
            // Some browsers return a Promise — handle rejection silently
            if (promise && typeof promise.catch === 'function') {
                promise.catch(() => {});
            }
        } catch (error) {
            // Ignore errors (autoplay policies, removed element, etc.)
        }
    };


    /**
     * Retrieve the client-side cart from localStorage.
     * Returns an array of cart items or empty array on parse errors.
     * @returns {Array<{id:string,title:string,price:string,qty:number}>}
     */
    const getCart = () => {
        try {
            return JSON.parse(localStorage.getItem('voidCart') || '[]');
        } catch (error) {
            // If storage contains invalid JSON, fallback to empty cart
            return [];
        }
    };


    /**
     * Persist the cart into localStorage.
     * @param {Array} cart - cart items to store
     */
    const setCart = (cart) => {
        localStorage.setItem('voidCart', JSON.stringify(cart));
    };


    /**
     * Update all DOM elements that carry the `data-cart-count` attribute
     * with the total item quantity currently present in the cart.
     * This keeps badges and header counters in sync with localStorage.
     */
    const updateCartBadge = () => {
        const cart = getCart();
        document.querySelectorAll('[data-cart-count]').forEach((node) => {
            node.textContent = cart.reduce((total, item) => total + (Number(item.qty) || 0), 0);
        });
    };


    /**
     * Render the visible cart pane.
     * - Finds elements by data attributes: `[data-cart-list]`, `[data-cart-total]`, `[data-cart-empty]`
     * - Produces a minimal DOM structure for each cart item.
     * - Shows/hides the empty-state and calculates the total.
     */
    const renderCart = () => {
        const cartList = document.querySelector('[data-cart-list]');
        const cartTotal = document.querySelector('[data-cart-total]');
        const cartEmpty = document.querySelector('[data-cart-empty]');

        // If essential nodes are missing, bail out silently (progressive enhancement)
        if (!cartList || !cartTotal) return;

        const cart = getCart();
        cartList.innerHTML = '';

        if (!cart.length) {
            if (cartEmpty) cartEmpty.style.display = 'block';
            cartTotal.textContent = '0';
            return;
        }

        if (cartEmpty) cartEmpty.style.display = 'none';

        let total = 0;

        cart.forEach((item) => {
            const price = Number(item.price) || 0;
            total += price * (Number(item.qty) || 0);

            const row = document.createElement('div');
            row.className = 'cart-item';
            // Keep rendered markup simple and accessible — quantity is presented as text
            row.innerHTML = `
                <div>
                    <strong>${escapeHtml(item.title)}</strong>
                    <span class="account-copy">Qty ${Number(item.qty)}</span>
                </div>
                <div class="release-price">${price ? price.toFixed(2) + ' €' : '—'}</div>
            `;
            cartList.appendChild(row);
        });

        cartTotal.textContent = total.toFixed(2);
    };


    /**
     * Minimal HTML-escaping utility to avoid injecting unsanitized values into innerHTML.
     * Note: this is intentionally simple and intended for small inline values only.
     * @param {string} value
     * @returns {string}
     */
    const escapeHtml = (value) => String(value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');


    /**
     * Initialize a simple review carousel with optional client-side submission.
     * The component is resilient: if expected DOM nodes are missing it will no-op.
     * - Uses cloning technique to create an infinite/seamless carousel track
     * - Supports manual prev/next and auto-play with hover pause
     */
    const initReviewCarousel = () => {
        const viewport = document.querySelector('[data-review-carousel]');
        const track = viewport ? viewport.querySelector('.review-carousel-track') : null;
        const prevButton = document.querySelector('[data-review-prev]');
        const nextButton = document.querySelector('[data-review-next]');
        const form = document.querySelector('[data-review-form]');

        // Progressive enhancement: if the carousel container or track is missing, abort
        if (!viewport || !track) return;

        const ratingButtons = form ? Array.from(form.querySelectorAll('[data-rating-value]')) : [];
        const ratingInput = form ? form.querySelector('[data-review-rating]') : null;
        const textInput = form ? form.querySelector('[data-review-text]') : null;

        // Default rating if none provided
        let activeRating = Number(ratingInput && ratingInput.value) || 5;

        // Snapshot original slides to allow cloning for infinite scroll effect
        let originalCards = Array.from(track.children).map((card) => card.cloneNode(true));
        let cloneCount = 0;
        let index = 0;
        let autoTimer = null;

        /**
         * Update rating control state
         * @param {number} value
         */
        const setRating = (value) => {
            activeRating = Math.max(1, Math.min(5, Number(value) || 5));

            if (ratingInput) ratingInput.value = String(activeRating);

            // Toggle selected classes for visual feedback
            ratingButtons.forEach((button) => {
                const buttonValue = Number(button.dataset.ratingValue) || 0;
                button.classList.toggle('is-selected', buttonValue <= activeRating);
            });
        };

        /**
         * Create a DOM card from a review object.
         * Escapes textual content and marks rating with decorative images.
         */
        const createCard = (review) => {
            const card = document.createElement('article');
            card.className = 'review-card review-carousel-card';
            const rating = Math.max(1, Math.min(5, Number(review.rating) || 5));

            card.innerHTML = `
                <div class="review-mark"><img src="img/skull.png" alt="" aria-hidden="true"></div>
                <p>${escapeHtml(review.text || '')}</p>
                <div class="review-rating" aria-label="Rating ${rating} out of 5">
                    ${Array.from({ length: 5 }, (_, skullIndex) => {
                        const activeClass = skullIndex < rating ? ' is-active' : '';
                        return `<img src="img/skull.png" alt="" class="review-rating-skull${activeClass}">`;
                    }).join('')}
                </div>
                <span>${escapeHtml(review.date || 'Featured review')}</span>
            `;

            return card;
        };

        /**
         * Rebuild the track using clones of original cards with pre/post clones
         * to allow smooth wrapping behaviour.
         */
        const rebuildCarousel = () => {
            const cards = originalCards.map((card) => card.cloneNode(true));
            // Keep up to three clones on each side to ensure visible continuity
            cloneCount = Math.min(3, cards.length);

            track.innerHTML = '';
            // prepend clones from the end
            cards.slice(-cloneCount).forEach((card) => track.appendChild(card.cloneNode(true)));
            // main sequence
            cards.forEach((card) => track.appendChild(card.cloneNode(true)));
            // append clones from the start
            cards.slice(0, cloneCount).forEach((card) => track.appendChild(card.cloneNode(true)));

            index = cloneCount;
        };

        /**
         * Compute translate offset by reading offsetLeft of the current card.
         * Returns 0 when card not available.
         */
        const getOffset = () => {
            const card = track.children[index] || track.children[cloneCount];
            if (!card) return 0;
            return card.offsetLeft;
        };

        /**
         * Update visual transform of the track. If animate=false, disables transition
         * to allow instant jump (used when normalizing loop wrap).
         * @param {boolean} animate
         */
        const syncPosition = (animate = false) => {
            track.style.transition = animate ? 'transform 650ms ease' : 'none';
            track.style.transform = `translateX(-${getOffset()}px)`;
        };

        // Move one logical step forward/backward
        const move = (direction) => {
            index += direction;
            syncPosition(true);
        };

        /**
         * When the CSS transition completes, ensure the index stays within the
         * valid range and jump instantly to the equivalent position if wrapped.
         */
        const normalize = () => {
            const originalLength = originalCards.length;

            if (index >= cloneCount + originalLength) {
                // Wrapped forward beyond the cloned tail; jump back to original start
                index = cloneCount;
                syncPosition(false);
            }

            if (index < cloneCount) {
                // Wrapped backward beyond the cloned head; jump to original end
                index = cloneCount + originalLength - 1;
                syncPosition(false);
            }
        };

        // Auto-play timer management
        const restartAuto = () => {
            if (autoTimer) clearInterval(autoTimer);
            autoTimer = setInterval(() => move(1), 4500);
        };

        // Wire rating buttons to update state
        ratingButtons.forEach((button) => {
            button.addEventListener('click', () => {
                setRating(Number(button.dataset.ratingValue) || 5);
            });
        });

        prevButton?.addEventListener('click', () => move(-1));
        nextButton?.addEventListener('click', () => move(1));

        track.addEventListener('transitionend', normalize);

        // Pause auto-play while mouse is over viewport
        viewport.addEventListener('mouseenter', () => {
            if (autoTimer) {
                clearInterval(autoTimer);
                autoTimer = null;
            }
        });

        viewport.addEventListener('mouseleave', restartAuto);

        // Recompute positions on resize
        window.addEventListener('resize', () => syncPosition(false));

        // Optional review submission handling: injects client-side card
        if (form) {
            form.addEventListener('submit', (event) => {
                // If the form is wired to a server action 'insertcomment' keep default behaviour
                if ((form.getAttribute('action') || '').indexOf('insertcomment') !== -1) return;

                event.preventDefault();

                const text = textInput ? textInput.value.trim() : '';
                if (!text) return; // ignore empty submissions

                originalCards.unshift(createCard({ text, date: 'Just now', rating: activeRating }));

                rebuildCarousel();
                setRating(activeRating);
                syncPosition(false);

                if (textInput) textInput.value = '';
            });
        }

        // Initialize the visual state
        rebuildCarousel();
        setRating(activeRating);
        syncPosition(false);
        restartAuto();
    };


    /**
     * Open/close helper for generic popup nodes. Handles accessibility attributes
     * and prevents background scrolling by toggling helper classes on <html> and <body>.
     * @param {HTMLElement} popup - popup element to toggle
     * @param {boolean} isOpen - true to open, false to close
     */
    const setPopupState = (popup, isOpen) => {
        if (!popup) return;

        // Move popup into document root to avoid z-index clipping inside containers
        if (isOpen && popup.parentElement !== document.documentElement) {
            document.documentElement.appendChild(popup);
        }

        popup.classList.toggle('is-open', isOpen);
        popup.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
        document.documentElement.classList.toggle('modal-scroll-lock', isOpen);
        document.body.classList.toggle('modal-scroll-lock', isOpen);
    };


    /**
     * Convenience: open a popup by id (default: newsletter popup)
     * @param {string} [popupId='newsletterPopup']
     */
    const openPopup = (popupId = 'newsletterPopup') => {
        setPopupState(document.getElementById(popupId), true);
    };


    /**
     * Convenience: close a popup node or the default newsletter popup.
     * When closing the newsletter popup, mark it as seen in sessionStorage.
     * @param {HTMLElement|null} popup
     */
    const closePopup = (popup) => {
        const targetPopup = popup || document.getElementById('newsletterPopup');
        setPopupState(targetPopup, false);
        if (targetPopup && targetPopup.id === 'newsletterPopup') {
            sessionStorage.setItem('voidNewsletterSeenHome', '1');
        }
    };


    /**
     * Simple signed-in check using a data-user-id attribute on the <body>.
     * This avoids coupling to a full auth library — the server template sets this.
     * @returns {boolean}
     */
    const isSignedIn = () => Boolean(document.body && document.body.dataset && document.body.dataset.userId);


    /**
     * Open the lightweight 'auth required' modal (used when guests attempt restricted actions)
     */
    const openAuthModal = () => {
        const modal = document.getElementById('authRequiredModal');
        if (!modal) return;

        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
        document.documentElement.classList.add('modal-scroll-lock');
        document.body.classList.add('modal-scroll-lock');
    };


    /**
     * Close the 'auth required' modal if present
     */
    const closeAuthModal = () => {
        const modal = document.getElementById('authRequiredModal');
        if (!modal) return;

        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
        document.documentElement.classList.remove('modal-scroll-lock');
        document.body.classList.remove('modal-scroll-lock');
    };


    /**
     * Global click handler for multiple UI affordances:
     * - Card click navigation (data-card-link + data-href)
     * - Add-to-cart behaviour (data-add-to-cart) with auth gating
     * - Generic popup close handlers (data-popup-close)
     * - Triggers click sound for anchors/buttons
     */
    document.addEventListener('click', (event) => {
        const clickableCard = event.target.closest('[data-card-link]');
        const addToCartButton = event.target.closest('[data-add-to-cart]');
        const popupClose = event.target.closest('[data-popup-close]');
        const interactive = event.target.closest('a, button, input, select, textarea, label');

        // Navigate when clicking a card that is not an interactive control inside
        if (clickableCard && !interactive) {
            const href = clickableCard.getAttribute('data-href');
            if (href) {
                window.location.href = href;
                playClick();
            }
            return;
        }

        // Handle add-to-cart events uniformly. The button is expected to expose
        // data-id, data-title and optional data-price attributes.
        if (addToCartButton) {
            event.preventDefault();
            // If user not signed in, show auth modal instead of mutating the cart
            if (!isSignedIn()) {
                openAuthModal();
                return;
            }

            // Build a normalized item structure and persist it in localStorage
            const item = {
                id: addToCartButton.dataset.id,
                title: addToCartButton.dataset.title,
                price: addToCartButton.dataset.price || '0',
                qty: 1,
            };

            const cart = getCart();
            const existing = cart.find((entry) => entry.id === item.id);
            if (existing) {
                existing.qty += 1; // increment quantity for repeated adds
            } else {
                cart.push(item);
            }

            setCart(cart);
            updateCartBadge();
            renderCart();
            playClick();
            return;
        }

        // Close popup if a close control is clicked
        if (popupClose) {
            closePopup(popupClose.closest('.newsletter-popup'));
            return;
        }

        // If click directly on the popup backdrop element, treat it as close
        if (event.target.classList && event.target.classList.contains('newsletter-popup')) {
            closePopup(event.target);
            return;
        }

        // Play click feedback for anchors and buttons
        if (event.target.tagName === 'A' || event.target.tagName === 'BUTTON') playClick();
    });


    /**
     * Wishlist heart toggle handler.
     * - Prevents default link navigation
     * - Opens auth modal for guests
     * - Calls server endpoint via fetch to toggle status for logged-in users
     * - Performs optimistic UI update on success
     */
    document.addEventListener('click', (event) => {
        const heartLink = event.target.closest('a.wishlist-heart');
        if (!heartLink) return;

        event.preventDefault();
        if (!isSignedIn()) {
            openAuthModal();
            return;
        }

        const url = heartLink.href;
        if (!url) return;

        const isActive = heartLink.classList.contains('active');

        // Perform the toggle request — server must return 2xx for success
        fetch(url, { method: 'GET', credentials: 'same-origin', redirect: 'follow' })
            .then((response) => {
                if (!response.ok) throw new Error('Wishlist request failed');
                // Toggle UI state on success (optimistic, idempotent on success)
                heartLink.classList.toggle('active', !isActive);
                heartLink.textContent = isActive ? '♡' : '♥';
                heartLink.style.color = isActive ? 'rgba(255, 255, 255, 0.78)' : '#ff4d4d';
            })
            .catch(() => {
                // If the request fails we keep the previous visual state — user can retry
            });
    });
        setTimeout(() => {
            cursor.style.display = 'none';
            form.classList.remove('hidden');
        }, 3600);
    }

    if (newsletterPopup && isHomePage && !sessionStorage.getItem('voidNewsletterSeenHome')) {
        setTimeout(() => {
            if (!sessionStorage.getItem('voidNewsletterSeenHome')) {
                openPopup('newsletterPopup');
            }
        }, 8000);
    }

    updateCartBadge();
    renderCart();
    initReviewCarousel();
});

document.addEventListener('submit', (event) => {
    const form = event.target;
    if (!form || !form.classList || !form.classList.contains('newsletter-form')) {
        return;
    }

    // Alert removed - success feedback now shown via redirect to answerNewsletter.php
});
